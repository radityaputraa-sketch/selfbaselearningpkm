# MODUL 2: SENSOR MANAGER
# ═══════════════════════════════════════════════════════════
class SensorManager:
    """
    Kelola pembacaan sensor:
    - MPU6050: akselerometer 3-axis (getaran)
    - MLX90614: sensor suhu infrared
    - MAX9814: mikrofon analog (via ADC MCP3008)
    """

    MPU6050_ADDR = 0x68
    MPU_PWR_REG  = 0x6B
    ACCEL_XOUT   = 0x3B

    def __init__(self):
        self.hardware = HARDWARE_AVAILABLE
        if self.hardware:
            self._init_mpu6050()
            self._init_temp_sensor()
        else:
            print("[SensorManager] Simulasi mode aktif")

    def _init_mpu6050(self):
        try:
            self.bus = smbus2.SMBus(1)
            # Wake up MPU6050
            self.bus.write_byte_data(self.MPU6050_ADDR, self.MPU_PWR_REG, 0)
            time.sleep(0.1)
        except Exception as e:
            print(f"[MPU6050] Error init: {e}")
            self.hardware = False

    def _init_temp_sensor(self):
        try:
            i2c = busio.I2C(board.SCL, board.SDA)
            self.mlx = MLX90614(i2c)
        except Exception as e:
            print(f"[MLX90614] Error init: {e}")

    def read_accel_raw(self) -> tuple[float, float, float]:
        """Baca akselerometer MPU6050, return (ax, ay, az) dalam g."""
        if not self.hardware:
            # Simulasi getaran normal + noise
            t = time.time()
            ax = 0.5 * np.sin(2 * np.pi * 50 * t) + np.random.normal(0, 0.05)
            ay = 0.3 * np.sin(2 * np.pi * 100 * t) + np.random.normal(0, 0.03)
            az = 1.0 + np.random.normal(0, 0.02)
            return ax, ay, az

        try:
            data = self.bus.read_i2c_block_data(self.MPU6050_ADDR, self.ACCEL_XOUT, 6)
            def to_int(h, l):
                val = (h << 8) | l
                return val - 65536 if val >= 32768 else val

            ax = to_int(data[0], data[1]) / 16384.0
            ay = to_int(data[2], data[3]) / 16384.0
            az = to_int(data[4], data[5]) / 16384.0
            return ax, ay, az
        except Exception as e:
            return 0.0, 0.0, 1.0

    def read_temperature(self) -> float:
        """Baca suhu objek (mesin) dari MLX90614 dalam Celsius."""
        if not self.hardware:
            return 40.0 + np.random.normal(0, 0.5)
        try:
            return self.mlx.object_temperature
        except:
            return 0.0

    def read_audio_rms(self) -> float:
        """
        Baca level suara dari MAX9814.
        Dalam implementasi nyata, bisa pakai ADC MCP3008 via SPI.
        Simulasi: nilai RMS sinyal audio.
        """
        if not self.hardware:
            return 0.15 + abs(np.random.normal(0, 0.02))
        # TODO: implementasi baca ADC SPI MCP3008
        return 0.15

    def record_vibration(self, duration_sec: float,
                          sample_rate: int = SAMPLE_RATE,
                          progress_cb=None) -> dict:
        """
        Rekam sinyal getaran selama duration_sec detik.
        Return dict berisi array time-domain dan metadata.
        """
        n_samples = int(duration_sec * sample_rate)
        interval  = 1.0 / sample_rate

        ax_data, ay_data, az_data = [], [], []
        temp_data, audio_data = [], []

        print(f"[Sensor] Mulai rekam {duration_sec}s @ {sample_rate}Hz...")
        start = time.time()

        for i in range(n_samples):
            t0 = time.time()

            ax, ay, az = self.read_accel_raw()
            temp       = self.read_temperature() if i % 100 == 0 else (temp_data[-1] if temp_data else 0)
            audio      = self.read_audio_rms() if i % 50 == 0 else (audio_data[-1] if audio_data else 0)

            ax_data.append(ax)
            ay_data.append(ay)
            az_data.append(az)
            temp_data.append(temp)
            audio_data.append(audio)

            # Progress callback setiap 1 detik
            if progress_cb and i % sample_rate == 0:
                progress_cb(i / n_samples, i // sample_rate, duration_sec)

            # Jaga timing
            elapsed = time.time() - t0
            sleep_t = max(0, interval - elapsed)
            if sleep_t > 0:
                time.sleep(sleep_t)

        elapsed_total = time.time() - start
        print(f"[Sensor] Rekaman selesai: {elapsed_total:.1f}s, {len(ax_data)} samples")

        return {
            "ax": np.array(ax_data),
            "ay": np.array(ay_data),
            "az": np.array(az_data),
            "temp": np.array(temp_data),
            "audio": np.array(audio_data),
            "sample_rate": sample_rate,
            "duration": elapsed_total,
            "n_samples": len(ax_data)
        }


