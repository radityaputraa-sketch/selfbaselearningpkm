# MODUL 3: FEATURE EXTRACTOR (FFT + STATISTIK)
# ═══════════════════════════════════════════════════════════
class FeatureExtractor:
    """
    Ekstrak fitur dari sinyal sensor menggunakan FFT dan statistik.
    Ini adalah inti dari self-baseline learning VIBRIS.
    """

    def extract(self, raw_data: dict) -> dict:
        """Ekstrak semua fitur dari raw recording."""
        ax = raw_data["ax"]
        ay = raw_data["ay"]
        az = raw_data["az"]
        sr = raw_data["sample_rate"]
        temp   = raw_data["temp"]
        audio  = raw_data["audio"]

        # Hitung magnitude getaran 3-axis
        vib_magnitude = np.sqrt(ax**2 + ay**2 + az**2)

        # Fitur statistik domain waktu
        vib_feats = self._time_domain_features(vib_magnitude)

        # Fitur domain frekuensi (FFT)
        fft_feats = self._frequency_domain_features(vib_magnitude, sr)

        # Fitur suhu
        temp_feats = self._temperature_features(temp)

        # Fitur akustik
        audio_feats = self._acoustic_features(audio, sr)

        return {
            **vib_feats,
            **fft_feats,
            **temp_feats,
            **audio_feats,
            "durasi": raw_data["duration"]
        }

    def _time_domain_features(self, sig: np.ndarray) -> dict:
        """Fitur statistik domain waktu."""
        from scipy.stats import kurtosis, skew
        return {
            "vib_mean":     float(np.mean(sig)),
            "vib_std":      float(np.std(sig)),
            "vib_rms":      float(np.sqrt(np.mean(sig**2))),
            "vib_peak":     float(np.max(np.abs(sig))),
            "vib_kurtosis": float(kurtosis(sig)),
            "vib_skewness": float(skew(sig)),
            "vib_crest":    float(np.max(np.abs(sig)) / (np.sqrt(np.mean(sig**2)) + 1e-9)),
            "vib_histogram": list(np.histogram(sig, bins=20)[0].astype(int))
        }

    def _frequency_domain_features(self, sig: np.ndarray, sr: int) -> dict:
        """Analisis FFT - identifikasi frekuensi dominan & energi per band."""
        # Windowing untuk mengurangi spectral leakage
        win = np.hanning(len(sig))
        sig_w = sig * win

        # FFT
        N = len(sig_w)
        yf = np.abs(fft(sig_w))[:N//2] * 2.0 / N
        xf = fftfreq(N, 1.0/sr)[:N//2]

        # Simpan spektrum ringkas (setiap 2 Hz, max 512 titik)
        step = max(1, len(xf) // 256)
        spectrum_compact = list(zip(
            xf[::step].tolist(),
            yf[::step].tolist()
        ))

        # Cari 3 peak frekuensi dominan
        peaks_idx, props = signal.find_peaks(yf, height=np.max(yf)*0.05,
                                              distance=5)
        peaks_sorted = sorted(peaks_idx, key=lambda i: yf[i], reverse=True)[:3]

        p1_hz  = float(xf[peaks_sorted[0]]) if len(peaks_sorted) > 0 else 0
        p1_amp = float(yf[peaks_sorted[0]]) if len(peaks_sorted) > 0 else 0
        p2_hz  = float(xf[peaks_sorted[1]]) if len(peaks_sorted) > 1 else 0
        p2_amp = float(yf[peaks_sorted[1]]) if len(peaks_sorted) > 1 else 0
        p3_hz  = float(xf[peaks_sorted[2]]) if len(peaks_sorted) > 2 else 0
        p3_amp = float(yf[peaks_sorted[2]]) if len(peaks_sorted) > 2 else 0

        # Energi per band frekuensi
        def band_energy(f_low, f_high):
            mask = (xf >= f_low) & (xf < f_high)
            return float(np.sum(yf[mask]**2))

        return {
            "fft_peak1_hz":  p1_hz,  "fft_peak1_amp": p1_amp,
            "fft_peak2_hz":  p2_hz,  "fft_peak2_amp": p2_amp,
            "fft_peak3_hz":  p3_hz,  "fft_peak3_amp": p3_amp,
            "fft_band_low":  band_energy(0, 100),
            "fft_band_mid":  band_energy(100, 300),
            "fft_band_high": band_energy(300, 500),
            "fft_total_energy": float(np.sum(yf**2)),
            "fft_spectral_entropy": self._spectral_entropy(yf),
            "fft_spectrum": spectrum_compact[:128]   # ringkas untuk DB
        }

    def _spectral_entropy(self, yf: np.ndarray) -> float:
        """Entropi spektral - ukuran keteraturan frekuensi."""
        psd = yf**2
        psd_norm = psd / (np.sum(psd) + 1e-9)
        entropy = -np.sum(psd_norm * np.log2(psd_norm + 1e-9))
        return float(entropy)

    def _temperature_features(self, temp: np.ndarray) -> dict:
        return {
            "temp_mean": float(np.mean(temp)),
            "temp_std":  float(np.std(temp)),
            "temp_max":  float(np.max(temp)),
            "temp_rise": float(np.max(temp) - np.min(temp))  # kenaikan suhu
        }

    def _acoustic_features(self, audio: np.ndarray, sr: int) -> dict:
        rms = float(np.sqrt(np.mean(audio**2)))
        # Spectral centroid dari audio
        if len(audio) > 10:
            yf = np.abs(fft(audio))[:len(audio)//2]
            xf = fftfreq(len(audio), 1.0/sr)[:len(audio)//2]
            centroid = float(np.sum(xf * yf) / (np.sum(yf) + 1e-9))
        else:
            centroid = 0.0
        return {
            "audio_rms": rms,
            "audio_spectral_centroid": centroid
        }


