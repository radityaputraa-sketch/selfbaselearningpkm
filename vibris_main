"""
VIBRIS - Self-Baseline Learning System
Perangkat Diagnostik Cerdas untuk Deteksi Dini Kerusakan Mesin Rotasi

Hardware: Raspberry Pi 3 + MPU6050 (accelerometer) + MAX9814 (mic) + MLX90614 (suhu) + TFT 3.5"
Mekanisme: Self-Baseline Learning berbasis statistik (tanpa dataset berlabel)

Alur:
1. MODE BASELINE: Rekam mesin SEHAT selama 60 detik → simpan profil ke database
2. MODE DIAGNOSA: Rekam mesin target 2-3 menit → bandingkan dengan baseline
3. Sistem beri keputusan: NORMAL / ANOMALI + tingkat keparahan
"""

import os
import time
import json
import sqlite3
import threading
import numpy as np
from datetime import datetime
from pathlib import Path

# ---- Cek dan import library hardware ----
try:
    import smbus2
    import RPi.GPIO as GPIO
    import board
    import busio
    from adafruit_mlx90614 import MLX90614
    HARDWARE_AVAILABLE = True
except ImportError:
    HARDWARE_AVAILABLE = False
    print("[SIMULASI MODE] Hardware tidak terdeteksi, berjalan dalam mode simulasi")

# ---- Import FFT & UI ----
from scipy.fft import fft, fftfreq
import scipy.signal as signal

# ---- Konstanta Sistem ----
SAMPLE_RATE = 1000          # Hz sampling rate accelerometer
BASELINE_DURATION = 60      # detik rekam baseline
DIAGNOSIS_DURATION = 120    # detik rekam diagnosis (2 menit)
N_FFT = 512                 # ukuran FFT window
ANOMALY_THRESHOLD = 3.0     # Z-score threshold untuk anomali (sigma)
DB_PATH = Path("/home/pi/vibris_database.db")  # path database

# ---- Warna untuk TFT Display ----
COLOR_BG      = (10, 10, 30)
COLOR_NORMAL  = (0, 220, 120)
COLOR_WARNING = (255, 200, 0)
COLOR_DANGER  = (255, 60, 60)
COLOR_ACCENT  = (80, 160, 255)
COLOR_WHITE   = (255, 255, 255)
COLOR_GRAY    = (120, 120, 140)


# ═══════════════════════════════════════════════════════════
# MODUL 1: DATABASE MANAGER
# ═══════════════════════════════════════════════════════════
class VibrisDatabase:
    """Kelola penyimpanan baseline dan riwayat diagnosa."""

    def __init__(self, db_path: Path = DB_PATH):
        self.db_path = db_path
        self._init_db()

    def _init_db(self):
        conn = sqlite3.connect(self.db_path)
        cur = conn.cursor()

        # Tabel baseline: profil mesin sehat
        cur.execute("""
            CREATE TABLE IF NOT EXISTS baselines (
                id          INTEGER PRIMARY KEY AUTOINCREMENT,
                mesin_id    TEXT NOT NULL,
                nama_mesin  TEXT NOT NULL,
                created_at  TEXT NOT NULL,
                durasi_detik INTEGER,
                -- Statistik getaran (akselerometer)
                vib_mean    REAL,
                vib_std     REAL,
                vib_rms     REAL,
                vib_kurtosis REAL,
                -- Statistik frekuensi dominan (FFT peaks)
                fft_peak1_hz REAL,
                fft_peak1_amp REAL,
                fft_peak2_hz REAL,
                fft_peak2_amp REAL,
                fft_band_low REAL,    -- energi 0-100 Hz
                fft_band_mid REAL,    -- energi 100-300 Hz
                fft_band_high REAL,   -- energi 300-500 Hz
                -- Statistik suhu
                temp_mean   REAL,
                temp_std    REAL,
                temp_max    REAL,
                -- Statistik akustik
                audio_rms   REAL,
                audio_spectral_centroid REAL,
                -- Data mentah histogram (JSON)
                vib_histogram TEXT,
                fft_spectrum  TEXT
            )
        """)

        # Tabel diagnosa: riwayat pemeriksaan
        cur.execute("""
            CREATE TABLE IF NOT EXISTS diagnoses (
                id          INTEGER PRIMARY KEY AUTOINCREMENT,
                baseline_id INTEGER REFERENCES baselines(id),
                mesin_id    TEXT NOT NULL,
                diagnosed_at TEXT NOT NULL,
                durasi_detik INTEGER,
                -- Skor anomali
                score_vibration REAL,
                score_frequency REAL,
                score_thermal   REAL,
                score_acoustic  REAL,
                score_total     REAL,
                -- Verdict
                verdict     TEXT,     -- NORMAL / WARNING / DANGER
                fault_type  TEXT,     -- bearing_fault / unbalance / misalignment / normal
                confidence  REAL,
                -- Detail fitur
                features    TEXT      -- JSON fitur lengkap
            )
        """)

        conn.commit()
        conn.close()

    def save_baseline(self, mesin_id: str, nama_mesin: str, features: dict) -> int:
        """Simpan baseline mesin sehat. Return ID baseline."""
        conn = sqlite3.connect(self.db_path)
        cur = conn.cursor()
        cur.execute("""
            INSERT INTO baselines (
                mesin_id, nama_mesin, created_at, durasi_detik,
                vib_mean, vib_std, vib_rms, vib_kurtosis,
                fft_peak1_hz, fft_peak1_amp, fft_peak2_hz, fft_peak2_amp,
                fft_band_low, fft_band_mid, fft_band_high,
                temp_mean, temp_std, temp_max,
                audio_rms, audio_spectral_centroid,
                vib_histogram, fft_spectrum
            ) VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)
        """, (
            mesin_id, nama_mesin,
            datetime.now().isoformat(),
            features.get("durasi", BASELINE_DURATION),
            features["vib_mean"], features["vib_std"],
            features["vib_rms"], features["vib_kurtosis"],
            features["fft_peak1_hz"], features["fft_peak1_amp"],
            features["fft_peak2_hz"], features["fft_peak2_amp"],
            features["fft_band_low"], features["fft_band_mid"], features["fft_band_high"],
            features["temp_mean"], features["temp_std"], features["temp_max"],
            features["audio_rms"], features["audio_spectral_centroid"],
            json.dumps(self._to_json(features.get("vib_histogram", []))),
            json.dumps(self._to_json(features.get("fft_spectrum", [])))
        ))
        baseline_id = cur.lastrowid
        conn.commit()
        conn.close()
        return baseline_id

    @staticmethod
    def _to_json(obj):
        """Convert numpy types to Python native for JSON serialization."""
        import numpy as np
        if isinstance(obj, (np.integer,)): return int(obj)
        if isinstance(obj, (np.floating,)): return float(obj)
        if isinstance(obj, np.ndarray): return obj.tolist()
        if isinstance(obj, dict): return {k: VibrisDatabase._to_json(v) for k, v in obj.items()}
        if isinstance(obj, (list, tuple)): return [VibrisDatabase._to_json(x) for x in obj]
        return obj

    def get_baseline(self, mesin_id: str) -> dict | None:
        """Ambil baseline terbaru untuk mesin tertentu."""
        conn = sqlite3.connect(self.db_path)
        conn.row_factory = sqlite3.Row
        cur = conn.cursor()
        cur.execute("""
            SELECT * FROM baselines
            WHERE mesin_id = ?
            ORDER BY created_at DESC
            LIMIT 1
        """, (mesin_id,))
        row = cur.fetchone()
        conn.close()
        return dict(row) if row else None

    def list_machines(self) -> list:
        """Daftar semua mesin yang punya baseline."""
        conn = sqlite3.connect(self.db_path)
        cur = conn.cursor()
        cur.execute("""
            SELECT mesin_id, nama_mesin, MAX(created_at) as last_baseline,
                   COUNT(*) as n_baselines
            FROM baselines
            GROUP BY mesin_id
            ORDER BY last_baseline DESC
        """)
        rows = cur.fetchall()
        conn.close()
        return [{"mesin_id": r[0], "nama_mesin": r[1],
                 "last_baseline": r[2], "n_baselines": r[3]} for r in rows]

    def save_diagnosis(self, result: dict) -> int:
        """Simpan hasil diagnosa."""
        conn = sqlite3.connect(self.db_path)
        cur = conn.cursor()
        cur.execute("""
            INSERT INTO diagnoses (
                baseline_id, mesin_id, diagnosed_at, durasi_detik,
                score_vibration, score_frequency, score_thermal, score_acoustic,
                score_total, verdict, fault_type, confidence, features
            ) VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?)
        """, (
            result.get("baseline_id"), result["mesin_id"],
            datetime.now().isoformat(),
            result.get("durasi", DIAGNOSIS_DURATION),
            result["score_vibration"], result["score_frequency"],
            result["score_thermal"], result["score_acoustic"],
            result["score_total"],
            result["verdict"], result["fault_type"], result["confidence"],
            json.dumps(self._to_json(result.get("features", {})))
        ))
        diag_id = cur.lastrowid
        conn.commit()
        conn.close()
        return diag_id

    def get_diagnosis_history(self, mesin_id: str, limit: int = 10) -> list:
        """Riwayat diagnosa suatu mesin."""
        conn = sqlite3.connect(self.db_path)
        conn.row_factory = sqlite3.Row
        cur = conn.cursor()
        cur.execute("""
            SELECT * FROM diagnoses
            WHERE mesin_id = ?
            ORDER BY diagnosed_at DESC
            LIMIT ?
        """, (mesin_id, limit))
        rows = cur.fetchall()
        conn.close()
        return [dict(r) for r in rows]


