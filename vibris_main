# MODUL 5: TFT DISPLAY UI
# ═══════════════════════════════════════════════════════════
class VibrisDisplay:
    """
    Antarmuka TFT 3.5" untuk VIBRIS.
    Mendukung layar Waveshare/Pimoroni 3.5" (480x320).
    Fallback ke terminal jika display tidak tersedia.
    """

    SCREEN_W = 480
    SCREEN_H = 320

    def __init__(self):
        self.pygame_available = False
        self._init_display()

    def _init_display(self):
        try:
            import pygame
            pygame.init()
            self.screen = pygame.display.set_mode(
                (self.SCREEN_W, self.SCREEN_H)
            )
            pygame.display.set_caption("VIBRIS Diagnostic System")
            self.pygame = pygame
            self.font_big   = pygame.font.SysFont("monospace", 32, bold=True)
            self.font_med   = pygame.font.SysFont("monospace", 20)
            self.font_small = pygame.font.SysFont("monospace", 14)
            self.pygame_available = True
            print("[Display] TFT display initialized")
        except Exception as e:
            print(f"[Display] Display tidak tersedia ({e}), mode terminal aktif")

    def show_home(self, machines: list):
        """Tampilkan layar utama: daftar mesin + menu."""
        if not self.pygame_available:
            self._terminal_home(machines)
            return

        pg = self.pygame
        self.screen.fill(COLOR_BG)
        self._draw_header("VIBRIS DIAGNOSTIC SYSTEM")

        y = 70
        self._text("Pilih Mesin / Aksi:", (20, y), COLOR_ACCENT, "med")
        y += 30

        menu_items = [
            ("1", "Rekam Baseline Baru", COLOR_ACCENT),
            ("2", "Diagnosa Mesin",      COLOR_NORMAL),
            ("3", "Riwayat Diagnosa",    COLOR_WHITE),
            ("4", "Pengaturan",          COLOR_GRAY),
        ]

        for key, label, color in menu_items:
            rect = pg.Rect(20, y, self.SCREEN_W - 40, 40)
            pg.draw.rect(self.screen, (30, 30, 60), rect, border_radius=8)
            pg.draw.rect(self.screen, color, rect, 1, border_radius=8)
            self._text(f"[{key}] {label}", (35, y + 10), color, "med")
            y += 48

        pg.display.flip()

    def show_recording(self, mode: str, progress: float,
                        elapsed: int, total: int,
                        realtime_vib: float = 0.0):
        """Tampilkan layar rekaman dengan progress bar."""
        if not self.pygame_available:
            pct = int(progress * 100)
            bar = "█" * (pct // 5) + "░" * (20 - pct // 5)
            print(f"\r[{mode}] [{bar}] {elapsed}/{total}s | Vib: {realtime_vib:.3f}g", end="")
            return

        pg = self.pygame
        self.screen.fill(COLOR_BG)
        self._draw_header(f"MODE: {mode}")

        # Indikator animasi rekam
        blink = int(time.time() * 2) % 2 == 0
        if blink:
            pg.draw.circle(self.screen, (255, 50, 50), (430, 40), 10)
            self._text("REC", (438, 30), (255, 50, 50), "small")

        # Timer
        self._text(f"Waktu: {elapsed} / {total} detik",
                   (20, 80), COLOR_WHITE, "med")

        # Progress bar
        bar_rect = pg.Rect(20, 120, self.SCREEN_W - 40, 30)
        pg.draw.rect(self.screen, (40, 40, 60), bar_rect, border_radius=15)
        fill_w = int((self.SCREEN_W - 40) * progress)
        if fill_w > 0:
            fill_rect = pg.Rect(20, 120, fill_w, 30)
            pg.draw.rect(self.screen, COLOR_ACCENT, fill_rect, border_radius=15)
        pg.draw.rect(self.screen, COLOR_GRAY, bar_rect, 1, border_radius=15)
        self._text(f"{int(progress*100)}%", (self.SCREEN_W//2 - 15, 125),
                   COLOR_WHITE, "med")

        # Level getaran realtime
        self._text(f"Getaran RMS: {realtime_vib:.4f} g",
                   (20, 170), COLOR_WHITE, "med")

        # Instruksi
        msg = ("Rekam mesin kondisi NORMAL" if mode == "BASELINE"
               else "Tempel alat ke mesin yang diperiksa")
        self._text(msg, (20, 210), COLOR_GRAY, "small")
        self._text("Tekan [CANCEL] untuk batal", (20, 240), COLOR_GRAY, "small")

        pg.display.flip()

    def show_result(self, result: dict):
        """Tampilkan hasil diagnosa."""
        if not self.pygame_available:
            self._terminal_result(result)
            return

        pg = self.pygame
        self.screen.fill(COLOR_BG)
        verdict = result["verdict"]
        color = {"NORMAL": COLOR_NORMAL, "WARNING": COLOR_WARNING,
                 "DANGER": COLOR_DANGER}.get(verdict, COLOR_WHITE)

        self._draw_header("HASIL DIAGNOSA")

        # Verdict besar
        self._text(verdict, (self.SCREEN_W//2 - 60, 70), color, "big")

        # Jenis kerusakan
        fault_label = {
            "normal":       "Kondisi Normal",
            "bearing_fault":"Kerusakan Bearing",
            "unbalance":    "Ketidakseimbangan Massa",
            "misalignment": "Misalignment Poros",
            "anomali_umum": "Anomali Terdeteksi"
        }.get(result.get("fault_type", ""), result.get("fault_type", ""))
        self._text(fault_label, (20, 115), COLOR_WHITE, "med")
        self._text(f"Confidence: {result['confidence']*100:.0f}%",
                   (20, 140), COLOR_GRAY, "small")

        # Skor per komponen
        y = 175
        components = [
            ("Getaran",  result["score_vibration"]),
            ("Frekuensi", result["score_frequency"]),
            ("Suhu",      result["score_thermal"]),
            ("Akustik",   result["score_acoustic"]),
        ]
        for label, score in components:
            bar_color = (COLOR_NORMAL if score < 1.5 else
                         COLOR_WARNING if score < 2.5 else COLOR_DANGER)
            self._text(f"{label:<10}", (20, y), COLOR_GRAY, "small")
            bar_w = min(int(score / 5.0 * 200), 200)
            pg.draw.rect(self.screen, (30, 40, 60), pg.Rect(120, y+2, 200, 14))
            if bar_w > 0:
                pg.draw.rect(self.screen, bar_color, pg.Rect(120, y+2, bar_w, 14))
            self._text(f"{score:.2f}σ", (330, y), bar_color, "small")
            y += 22

        # Total skor
        self._text(f"Skor Total: {result['score_total']:.2f}σ",
                   (20, y + 5), color, "med")

        # Tombol aksi
        self._button("SIMPAN & KEMBALI", (20, 290), COLOR_ACCENT)
        self._button("ULANGI", (260, 290), COLOR_GRAY)
        pg.display.flip()

    def show_baseline_saved(self, nama_mesin: str, baseline_id: int):
        """Konfirmasi baseline tersimpan."""
        if not self.pygame_available:
            print(f"\n✓ Baseline '{nama_mesin}' tersimpan (ID: {baseline_id})")
            return

        pg = self.pygame
        self.screen.fill(COLOR_BG)
        self._draw_header("BASELINE TERSIMPAN")
        self._text("✓", (self.SCREEN_W//2 - 10, 90), COLOR_NORMAL, "big")
        self._text(f"Mesin: {nama_mesin}", (20, 160), COLOR_WHITE, "med")
        self._text(f"ID Baseline: {baseline_id}", (20, 190), COLOR_GRAY, "small")
        self._text("Baseline siap digunakan untuk diagnosa",
                   (20, 220), COLOR_GRAY, "small")
        self._button("OK", (self.SCREEN_W//2 - 50, 270), COLOR_NORMAL)
        pg.display.flip()

    # ---- Helper ----
    def _draw_header(self, title: str):
        pg = self.pygame
        pg.draw.rect(self.screen, (20, 20, 50),
                     pg.Rect(0, 0, self.SCREEN_W, 60))
        pg.draw.line(self.screen, COLOR_ACCENT,
                     (0, 60), (self.SCREEN_W, 60), 1)
        self._text("VIBRIS", (10, 15), COLOR_ACCENT, "med")
        self._text(title, (90, 15), COLOR_WHITE, "med")

    def _text(self, msg: str, pos: tuple, color: tuple, size: str = "med"):
        if not self.pygame_available:
            return
        font = {"big": self.font_big, "med": self.font_med,
                "small": self.font_small}.get(size, self.font_med)
        surf = font.render(str(msg), True, color)
        self.screen.blit(surf, pos)

    def _button(self, label: str, pos: tuple, color: tuple, w: int = 200, h: int = 34):
        pg = self.pygame
        rect = pg.Rect(pos[0], pos[1], w, h)
        pg.draw.rect(self.screen, (20, 20, 50), rect, border_radius=8)
        pg.draw.rect(self.screen, color, rect, 2, border_radius=8)
        self._text(label, (pos[0]+10, pos[1]+7), color, "small")

    def _terminal_home(self, machines: list):
        print("\n" + "="*50)
        print("  VIBRIS DIAGNOSTIC SYSTEM")
        print("="*50)
        print("  [1] Rekam Baseline Baru")
        print("  [2] Diagnosa Mesin")
        print("  [3] Riwayat Diagnosa")
        print("  [4] Keluar")
        print("="*50)
        print(f"  Mesin terdaftar: {len(machines)}")

    def _terminal_result(self, result: dict):
        v = result["verdict"]
        icon = {"NORMAL": "✓", "WARNING": "⚠", "DANGER": "✗"}.get(v, "?")
        print(f"\n{'='*50}")
        print(f"  HASIL DIAGNOSA: {icon} {v}")
        print(f"  Jenis: {result.get('fault_type', '-')}")
        print(f"  Confidence: {result['confidence']*100:.0f}%")
        print(f"  Skor Total: {result['score_total']:.3f}σ")
        print(f"    - Getaran:  {result['score_vibration']:.3f}σ")
        print(f"    - Frekuensi:{result['score_frequency']:.3f}σ")
        print(f"    - Suhu:     {result['score_thermal']:.3f}σ")
        print(f"    - Akustik:  {result['score_acoustic']:.3f}σ")
        print("="*50)


