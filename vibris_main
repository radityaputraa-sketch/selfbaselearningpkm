# MODUL 6: VIBRIS CONTROLLER (State Machine Utama)
# ═══════════════════════════════════════════════════════════
class VibrisController:
    """
    State machine utama VIBRIS.
    State: HOME → BASELINE_SETUP → RECORDING → PROCESSING → RESULT
           HOME → DIAGNOSIS_SELECT → RECORDING → PROCESSING → RESULT
    """

    def __init__(self):
        self.db        = VibrisDatabase()
        self.sensor    = SensorManager()
        self.extractor = FeatureExtractor()
        self.detector  = AnomalyDetector()
        self.display   = VibrisDisplay()
        self.running   = True

    # ─────────────────────────────────────────
    # ALUR 1: REKAM BASELINE (mesin sehat)
    # ─────────────────────────────────────────
    def record_baseline(self, mesin_id: str, nama_mesin: str,
                         durasi: int = BASELINE_DURATION) -> int:
        """
        Rekam baseline mesin sehat.
        Tahap:
        1. Rekam sensor selama durasi detik
        2. Ekstrak fitur FFT + statistik
        3. Simpan ke database
        Return: baseline_id
        """
        print(f"\n[BASELINE] Mulai rekam '{nama_mesin}' selama {durasi}s...")

        def progress_cb(frac, elapsed, total):
            self.display.show_recording(
                "BASELINE", frac, elapsed, int(total),
                realtime_vib=np.random.uniform(0.4, 0.6)  # realtime dari sensor
            )

        # Rekam sensor
        raw = self.sensor.record_vibration(durasi, progress_cb=progress_cb)

        # Ekstrak fitur
        print("[BASELINE] Ekstrak fitur...")
        features = self.extractor.extract(raw)

        # Simpan ke database
        baseline_id = self.db.save_baseline(mesin_id, nama_mesin, features)
        print(f"[BASELINE] Tersimpan! ID: {baseline_id}")

        self.display.show_baseline_saved(nama_mesin, baseline_id)
        return baseline_id

    # ─────────────────────────────────────────
    # ALUR 2: DIAGNOSA MESIN
    # ─────────────────────────────────────────
    def diagnose_machine(self, mesin_id: str,
                          durasi: int = DIAGNOSIS_DURATION) -> dict:
        """
        Diagnosa kondisi mesin dengan membandingkan terhadap baseline.
        Return: dict hasil diagnosa
        """
        # Ambil baseline
        baseline = self.db.get_baseline(mesin_id)
        if baseline is None:
            print(f"[ERROR] Tidak ada baseline untuk mesin '{mesin_id}'!")
            print("  → Rekam baseline terlebih dahulu.")
            return {"error": "no_baseline"}

        print(f"\n[DIAGNOSA] Mulai diagnosa '{mesin_id}' selama {durasi}s...")

        def progress_cb(frac, elapsed, total):
            self.display.show_recording(
                "DIAGNOSA", frac, elapsed, int(total)
            )

        # Rekam sensor
        raw = self.sensor.record_vibration(durasi, progress_cb=progress_cb)

        # Ekstrak fitur
        print("[DIAGNOSA] Ekstrak fitur & analisis...")
        current_features = self.extractor.extract(raw)

        # Bandingkan dengan baseline (core self-baseline learning)
        result = self.detector.compare(baseline, current_features)
        result["mesin_id"]    = mesin_id
        result["baseline_id"] = baseline["id"]

        # Simpan hasil
        diag_id = self.db.save_diagnosis(result)
        result["diagnosis_id"] = diag_id

        # Tampilkan
        self.display.show_result(result)

        return result

    # ─────────────────────────────────────────
    # MENU INTERAKTIF TERMINAL
    # ─────────────────────────────────────────
    def run_interactive(self):
        """Loop menu interaktif (untuk terminal/testing)."""
        print("\n" + "="*50)
        print("  VIBRIS - Self-Baseline Diagnostic System")
        print("="*50)

        while self.running:
            machines = self.db.list_machines()
            self.display.show_home(machines)

            choice = input("\nPilih [1-4]: ").strip()

            if choice == "1":
                self._menu_record_baseline()
            elif choice == "2":
                self._menu_diagnose()
            elif choice == "3":
                self._menu_history()
            elif choice == "4":
                print("Sampai jumpa!")
                self.running = False
            else:
                print("Pilihan tidak valid.")

    def _menu_record_baseline(self):
        print("\n── REKAM BASELINE ──")
        mesin_id   = input("ID Mesin (contoh: motor_01): ").strip()
        nama_mesin = input("Nama Mesin (contoh: Blender ABC): ").strip()
        durasi     = input(f"Durasi rekam detik [{BASELINE_DURATION}]: ").strip()
        durasi     = int(durasi) if durasi.isdigit() else BASELINE_DURATION

        if not mesin_id:
            print("ID mesin tidak boleh kosong!")
            return

        print(f"\n⚡ Pastikan mesin MENYALA dalam kondisi NORMAL!")
        print(f"   Rekaman mulai dalam 3 detik...")
        time.sleep(3)

        self.record_baseline(mesin_id, nama_mesin, durasi)
        input("\nTekan Enter untuk kembali...")

    def _menu_diagnose(self):
        machines = self.db.list_machines()
        if not machines:
            print("\nBelum ada baseline. Rekam baseline dulu!")
            return

        print("\n── DIAGNOSA MESIN ──")
        print("Mesin dengan baseline:")
        for i, m in enumerate(machines, 1):
            print(f"  [{i}] {m['mesin_id']} - {m['nama_mesin']}")

        idx = input("Pilih nomor mesin: ").strip()
        if not idx.isdigit() or int(idx) < 1 or int(idx) > len(machines):
            print("Pilihan tidak valid!")
            return

        mesin = machines[int(idx) - 1]
        durasi = input(f"Durasi rekam detik [{DIAGNOSIS_DURATION}]: ").strip()
        durasi = int(durasi) if durasi.isdigit() else DIAGNOSIS_DURATION

        print(f"\n⚡ Tempel VIBRIS ke mesin yang akan diperiksa!")
        print(f"   Rekaman mulai dalam 3 detik...")
        time.sleep(3)

        result = self.diagnose_machine(mesin["mesin_id"], durasi)
        if "error" not in result:
            input("\nTekan Enter untuk kembali...")

    def _menu_history(self):
        machines = self.db.list_machines()
        if not machines:
            print("\nBelum ada data diagnosa.")
            return

        print("\n── RIWAYAT DIAGNOSA ──")
        for i, m in enumerate(machines, 1):
            print(f"  [{i}] {m['mesin_id']} - {m['nama_mesin']}")

        idx = input("Pilih nomor mesin: ").strip()
        if not idx.isdigit() or int(idx) < 1 or int(idx) > len(machines):
            return

        mesin = machines[int(idx) - 1]
        history = self.db.get_diagnosis_history(mesin["mesin_id"], limit=5)

        print(f"\nRiwayat diagnosa '{mesin['nama_mesin']}':")
        if not history:
            print("  Belum ada diagnosa.")
            return

        for h in history:
            icon = {"NORMAL": "✓", "WARNING": "⚠", "DANGER": "✗"}.get(h["verdict"], "?")
            print(f"  {icon} [{h['diagnosed_at'][:16]}] {h['verdict']} | "
                  f"Skor: {h['score_total']:.2f}σ | {h['fault_type']}")

        input("\nTekan Enter untuk kembali...")


