# MODUL 4: ANOMALY DETECTOR (SELF-BASELINE COMPARISON)
# ═══════════════════════════════════════════════════════════
class AnomalyDetector:
    """
    Inti self-baseline learning:
    Bandingkan fitur mesin yang diperiksa dengan baseline mesin sehat.
    Tidak perlu dataset berlabel - cukup rekaman mesin normal sebagai referensi.
    """

    # Bobot tiap komponen skor (total harus 1.0)
    WEIGHTS = {
        "vibration": 0.35,   # getaran paling penting
        "frequency": 0.35,   # pola frekuensi FFT
        "thermal":   0.15,   # suhu
        "acoustic":  0.15    # suara
    }

    def compare(self, baseline: dict, current_features: dict) -> dict:
        """
        Bandingkan current_features dengan baseline.
        Return dict hasil diagnosa lengkap.
        """
        # Hitung Z-score per dimensi fitur
        score_vib  = self._score_vibration(baseline, current_features)
        score_freq = self._score_frequency(baseline, current_features)
        score_temp = self._score_thermal(baseline, current_features)
        score_aud  = self._score_acoustic(baseline, current_features)

        # Skor total tertimbang
        score_total = (
            score_vib  * self.WEIGHTS["vibration"] +
            score_freq * self.WEIGHTS["frequency"] +
            score_temp * self.WEIGHTS["thermal"] +
            score_aud  * self.WEIGHTS["acoustic"]
        )

        # Tentukan verdict
        verdict, severity = self._verdict(score_total)

        # Identifikasi jenis kerusakan berdasarkan pola FFT
        fault_type, confidence = self._identify_fault(baseline, current_features, score_freq)

        return {
            "score_vibration": round(score_vib, 3),
            "score_frequency": round(score_freq, 3),
            "score_thermal":   round(score_temp, 3),
            "score_acoustic":  round(score_aud, 3),
            "score_total":     round(score_total, 3),
            "verdict":         verdict,
            "severity":        severity,
            "fault_type":      fault_type,
            "confidence":      round(confidence, 3),
            "features":        current_features
        }

    def _zscore(self, current: float, baseline_mean: float,
                 baseline_std: float) -> float:
        """Z-score: seberapa jauh current dari baseline (dalam satuan std)."""
        if baseline_std < 1e-9:
            return 0.0
        return abs(current - baseline_mean) / baseline_std

    def _score_vibration(self, bl: dict, cf: dict) -> float:
        """Skor anomali getaran (0 = normal, >3 = anomali)."""
        scores = [
            self._zscore(cf["vib_rms"],      bl["vib_rms"],      bl["vib_std"]),
            self._zscore(cf["vib_kurtosis"], bl["vib_kurtosis"], max(abs(bl["vib_kurtosis"])*0.1, 0.1)),
            self._zscore(cf["vib_std"],      bl["vib_std"],      max(bl["vib_std"]*0.1, 0.01)),
        ]
        return float(np.mean(scores))

    def _score_frequency(self, bl: dict, cf: dict) -> float:
        """Skor anomali pola frekuensi FFT."""
        scores = []

        # Pergeseran frekuensi dominan
        if bl.get("fft_peak1_hz", 0) > 1:
            hz_shift = abs(cf.get("fft_peak1_hz", 0) - bl["fft_peak1_hz"])
            scores.append(hz_shift / max(bl["fft_peak1_hz"] * 0.1, 1.0))

        # Perubahan distribusi energi per band
        for band in ["fft_band_low", "fft_band_mid", "fft_band_high"]:
            if bl.get(band, 0) > 1e-9:
                ratio = cf.get(band, 0) / bl[band]
                # Skor tinggi jika rasio jauh dari 1.0
                scores.append(abs(np.log2(ratio + 1e-9)))

        # Perubahan entropi spektral
        if bl.get("fft_spectral_entropy", 0) > 0:
            ent_change = abs(cf.get("fft_spectral_entropy", 0) - bl["fft_spectral_entropy"])
            scores.append(ent_change / max(bl["fft_spectral_entropy"] * 0.1, 0.1))

        return float(np.mean(scores)) if scores else 0.0

    def _score_thermal(self, bl: dict, cf: dict) -> float:
        """Skor anomali suhu."""
        # Kenaikan suhu signifikan = anomali
        temp_rise = cf.get("temp_mean", 0) - bl.get("temp_mean", 0)
        std_temp  = max(bl.get("temp_std", 1.0), 1.0)
        zscore    = max(0, temp_rise) / std_temp  # hanya naiknya yang dihitung
        return float(zscore)

    def _score_acoustic(self, bl: dict, cf: dict) -> float:
        """Skor anomali suara."""
        return self._zscore(
            cf.get("audio_rms", 0),
            bl.get("audio_rms", 0.15),
            max(bl.get("audio_rms", 0.15) * 0.2, 0.01)
        )

    def _verdict(self, score: float) -> tuple[str, int]:
        """Tentukan verdict berdasarkan skor total."""
        if score < 1.5:
            return "NORMAL", 0
        elif score < 2.5:
            return "WARNING", 1
        else:
            return "DANGER", 2

    def _identify_fault(self, bl: dict, cf: dict,
                         freq_score: float) -> tuple[str, float]:
        """
        Identifikasi jenis kerusakan berdasarkan pola FFT.
        Rule-based berdasarkan teori vibrasi mesin:
        - Bearing fault: energi tinggi di high-freq, kurtosis tinggi
        - Unbalance: dominan di 1x RPM (frekuensi dasar)
        - Misalignment: dominan di 2x RPM
        """
        if freq_score < 1.5:
            return "normal", 0.90

        # Hitung rasio energi band
        total_e = (cf.get("fft_band_low", 0) +
                   cf.get("fft_band_mid", 0) +
                   cf.get("fft_band_high", 0) + 1e-9)
        r_low  = cf.get("fft_band_low", 0) / total_e
        r_mid  = cf.get("fft_band_mid", 0) / total_e
        r_high = cf.get("fft_band_high", 0) / total_e

        bl_total_e = (bl.get("fft_band_low", 0) +
                      bl.get("fft_band_mid", 0) +
                      bl.get("fft_band_high", 0) + 1e-9)
        bl_r_high = bl.get("fft_band_high", 0) / bl_total_e

        kurt = cf.get("vib_kurtosis", 3.0)

        # Bearing fault: kurtosis > 4 + high-freq energy naik signifikan
        if kurt > 4.0 and r_high > bl_r_high * 1.5:
            return "bearing_fault", min(0.95, 0.6 + (kurt - 4.0) * 0.1)

        # Unbalance: energi dominan di low-freq + frekuensi peak bergeser ke 1x RPM area
        if r_low > 0.6 and cf.get("fft_peak1_amp", 0) > bl.get("fft_peak1_amp", 0) * 2:
            return "unbalance", 0.75

        # Misalignment: energy naik di mid-freq (harmonik 2x)
        if r_mid > 0.45 and cf.get("fft_peak2_amp", 0) > bl.get("fft_peak1_amp", 0) * 1.5:
            return "misalignment", 0.70

        return "anomali_umum", 0.60


