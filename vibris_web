<script>
// ═══════════════════════════
// State
// ═══════════════════════════
let recording = false;
let recordTimer = null;
let fftCtx = null;

// ═══════════════════════════
// Init
// ═══════════════════════════
window.onload = () => {
  fftCtx = document.getElementById('fft-canvas').getContext('2d');
  setInterval(updateClock, 1000);
  loadDashboard();
  setInterval(loadDashboard, 10000);
};

function updateClock() {
  document.getElementById('live-time').textContent =
    new Date().toLocaleTimeString('id-ID');
}

async function loadDashboard() {
  const [stats, machines, history] = await Promise.all([
    fetch('/api/stats').then(r => r.json()),
    fetch('/api/machines').then(r => r.json()),
    fetch('/api/history').then(r => r.json()),
  ]);

  document.getElementById('stat-machines').textContent = stats.machines;
  document.getElementById('stat-diagnoses').textContent = stats.diagnoses;
  document.getElementById('stat-anomalies').textContent = stats.anomalies;

  // Dropdown mesin
  const sel = document.getElementById('diag-machine-id');
  sel.innerHTML = '<option value="">-- Pilih Mesin --</option>';
  machines.forEach(m => {
    sel.innerHTML += `<option value="${m.mesin_id}">${m.nama_mesin} (${m.mesin_id})</option>`;
  });

  // Daftar mesin
  const ml = document.getElementById('machines-list');
  if (machines.length === 0) {
    ml.innerHTML = '<div style="color:#8080a0;padding:15px">Belum ada mesin. Rekam baseline terlebih dahulu.</div>';
  } else {
    ml.innerHTML = machines.map(m => `
      <div class="history-row">
        <span class="machine-tag">${m.mesin_id}</span>
        <span style="flex:1; margin-left:12px">${m.nama_mesin}</span>
        <span style="color:#8080a0; font-size:0.8em">
          Baseline: ${m.n_baselines}× | Terakhir: ${m.last_baseline?.substring(0,16) || '-'}
        </span>
        <button class="btn btn-success" style="padding:4px 12px; font-size:0.75em; margin-left:10px"
          onclick="quickDiagnose('${m.mesin_id}')">Diagnosa</button>
      </div>
    `).join('');
  }

  // Riwayat
  const hl = document.getElementById('history-list');
  if (history.length === 0) {
    hl.innerHTML = '<div style="color:#8080a0; text-align:center; padding:20px">Belum ada riwayat</div>';
  } else {
    hl.innerHTML = history.map(h => {
      const icon = {NORMAL:'✓', WARNING:'⚠', DANGER:'✗'}[h.verdict] || '?';
      const clr  = {NORMAL:'#00dc78', WARNING:'#ffc800', DANGER:'#ff3c3c'}[h.verdict] || '#fff';
      return `
        <div class="history-row">
          <span class="status-dot status-${h.verdict}"></span>
          <span style="color:${clr}; width:70px">${icon} ${h.verdict}</span>
          <span class="machine-tag">${h.mesin_id}</span>
          <span style="flex:1; margin-left:10px; color:#8080a0; font-size:0.8em">${h.fault_type}</span>
          <span style="color:#8080a0; font-size:0.8em">${h.score_total?.toFixed(2)}σ</span>
          <span style="color:#5050a0; font-size:0.75em; margin-left:10px">${h.diagnosed_at?.substring(0,16)}</span>
        </div>
      `;
    }).join('');
  }
}

// ═══════════════════════════
// Baseline
// ═══════════════════════════
async function startBaseline() {
  const machineId   = document.getElementById('baseline-machine-id').value.trim();
  const machineName = document.getElementById('baseline-machine-name').value.trim();
  const duration    = parseInt(document.getElementById('baseline-duration').value);

  if (!machineId || !machineName) {
    alert('ID dan Nama Mesin harus diisi!');
    return;
  }
  if (recording) {
    alert('Sedang merekam, tunggu selesai!');
    return;
  }

  showRecordingPanel('REKAM BASELINE', duration);

  try {
    const res = await fetch('/api/record_baseline', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({mesin_id: machineId, nama_mesin: machineName, durasi: duration})
    });
    const data = await res.json();
    stopRecordingPanel();
    if (data.success) {
      showAlert('✓ Baseline tersimpan! ID: ' + data.baseline_id, 'success');
      loadDashboard();
    } else {
      showAlert('Error: ' + data.error, 'danger');
    }
  } catch (e) {
    stopRecordingPanel();
    showAlert('Koneksi error: ' + e.message, 'danger');
  }
}

// ═══════════════════════════
// Diagnosa
// ═══════════════════════════
async function startDiagnosis() {
  const machineId = document.getElementById('diag-machine-id').value;
  const duration  = parseInt(document.getElementById('diag-duration').value);
  if (!machineId) { alert('Pilih mesin terlebih dahulu!'); return; }
  if (recording)  { alert('Sedang merekam!'); return; }

  await runDiagnosis(machineId, duration);
}

async function quickDiagnose(machineId) {
  if (recording) { alert('Sedang merekam!'); return; }
  await runDiagnosis(machineId, 120);
}

async function runDiagnosis(machineId, duration) {
  showRecordingPanel('DIAGNOSA', duration);
  try {
    const res = await fetch('/api/diagnose', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({mesin_id: machineId, durasi: duration})
    });
    const data = await res.json();
    stopRecordingPanel();
    if (data.success) {
      showResult(data.result);
      loadDashboard();
    } else {
      showAlert('Error: ' + (data.error || 'Unknown'), 'danger');
    }
  } catch (e) {
    stopRecordingPanel();
    showAlert('Koneksi error: ' + e.message, 'danger');
  }
}

// ═══════════════════════════
// UI Helper
// ═══════════════════════════
function showRecordingPanel(mode, total) {
  recording = true;
  document.getElementById('recording-panel').style.display = 'block';
  document.getElementById('result-panel').style.display = 'none';
  document.getElementById('rec-mode-title').textContent = '● ' + mode;

  let elapsed = 0;
  recordTimer = setInterval(() => {
    elapsed++;
    const pct = Math.min(100, (elapsed / total) * 100);
    document.getElementById('rec-elapsed').textContent = `${elapsed} / ${total} detik`;
    document.getElementById('rec-progress').style.width = pct + '%';
    document.getElementById('rec-vib').textContent =
      `Getaran RMS: ${(0.4 + Math.random()*0.2).toFixed(4)} g`;
    document.getElementById('rec-status').textContent =
      elapsed < total * 0.2 ? 'Memanaskan sensor...' :
      elapsed < total * 0.8 ? 'Mengambil sampel...' : 'Memproses FFT...';
    drawFakeFFT(elapsed);
  }, 1000);
}

function stopRecordingPanel() {
  recording = false;
  clearInterval(recordTimer);
}

function showResult(result) {
  document.getElementById('result-panel').style.display = 'block';
  const icons = {NORMAL:'✅', WARNING:'⚠️', DANGER:'🚨'};
  const colors = {NORMAL:'#00dc78', WARNING:'#ffc800', DANGER:'#ff3c3c'};
  const faultLabels = {
    normal:'Kondisi Normal', bearing_fault:'Kerusakan Bearing',
    unbalance:'Ketidakseimbangan Massa', misalignment:'Misalignment Poros',
    anomali_umum:'Anomali Terdeteksi'
  };
  const v = result.verdict;
  document.getElementById('result-icon').textContent = icons[v] || '?';
  document.getElementById('result-verdict').textContent = v;
  document.getElementById('result-verdict').style.color = colors[v];
  document.getElementById('result-fault').textContent = faultLabels[result.fault_type] || result.fault_type;
  document.getElementById('result-score').textContent = result.score_total?.toFixed(2) + 'σ';
  document.getElementById('result-score').style.color = colors[v];
  document.getElementById('result-confidence').textContent =
    `Tingkat keyakinan: ${(result.confidence * 100).toFixed(0)}%`;

  const comps = [
    ['Getaran',  result.score_vibration],
    ['Frekuensi', result.score_frequency],
    ['Suhu',      result.score_thermal],
    ['Akustik',   result.score_acoustic],
  ];
  const sc = document.getElementById('result-scores');
  sc.innerHTML = comps.map(([label, score]) => {
    const pct = Math.min(100, (score / 5) * 100);
    const clr = score < 1.5 ? '#00dc78' : score < 2.5 ? '#ffc800' : '#ff3c3c';
    return `
      <div class="score-bar">
        <span class="score-label">${label}</span>
        <div class="score-track">
          <div class="score-fill" style="width:${pct}%; background:${clr}"></div>
        </div>
        <span style="width:50px; text-align:right; color:${clr}; font-size:0.8em">
          ${score?.toFixed(2)}σ
        </span>
      </div>
    `;
  }).join('');
}

function showAlert(msg, type) {
  const al = document.createElement('div');
  al.className = `alert alert-${type}`;
  al.textContent = msg;
  document.querySelector('.container').prepend(al);
  setTimeout(() => al.remove(), 5000);
}

function drawFakeFFT(t) {
  const canvas = document.getElementById('fft-canvas');
  const ctx = fftCtx;
  const W = canvas.width = canvas.offsetWidth;
  const H = canvas.height;
  ctx.clearRect(0, 0, W, H);
  ctx.fillStyle = '#0a0a1e';
  ctx.fillRect(0, 0, W, H);
  ctx.strokeStyle = '#5090ff';
  ctx.lineWidth = 1.5;
  ctx.beginPath();
  for (let x = 0; x < W; x++) {
    const f = (x / W) * 500;
    let amp = 0;
    amp += 20 * Math.exp(-Math.pow(f - 50, 2) / 100) + Math.random() * 3;
    amp += 10 * Math.exp(-Math.pow(f - 100, 2) / 200) + Math.random() * 2;
    amp += 5  * Math.exp(-Math.pow(f - 200, 2) / 500) + Math.random() * 1;
    const y = H - (amp / 28) * H;
    x === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
  }
  ctx.stroke();
  // Label sumbu
  ctx.fillStyle = '#5050a0';
  ctx.font = '10px monospace';
  ctx.fillText('0', 2, H-2);
  ctx.fillText('250Hz', W/2 - 15, H-2);
  ctx.fillText('500Hz', W - 35, H-2);
}
</script>
</body>
</html>
"""

# ═══════════════════════════════════════════════════════════
# API ENDPOINTS
# ═══════════════════════════════════════════════════════════

@app.route("/")
def index():
    return render_template_string(HTML_TEMPLATE)

@app.route("/api/stats")
def api_stats():
    conn = sqlite3.connect(DB_PATH)
    cur = conn.cursor()
    machines  = cur.execute("SELECT COUNT(DISTINCT mesin_id) FROM baselines").fetchone()[0]
    diagnoses = cur.execute("SELECT COUNT(*) FROM diagnoses").fetchone()[0]
    anomalies = cur.execute(
        "SELECT COUNT(*) FROM diagnoses WHERE verdict != 'NORMAL'"
    ).fetchone()[0]
    conn.close()
    return jsonify({"machines": machines, "diagnoses": diagnoses, "anomalies": anomalies})

@app.route("/api/machines")
def api_machines():
    conn = sqlite3.connect(DB_PATH)
    cur = conn.cursor()
    cur.execute("""
        SELECT mesin_id, nama_mesin, MAX(created_at) as last_baseline,
               COUNT(*) as n_baselines
        FROM baselines GROUP BY mesin_id ORDER BY last_baseline DESC
    """)
    rows = [{"mesin_id": r[0], "nama_mesin": r[1],
             "last_baseline": r[2], "n_baselines": r[3]}
            for r in cur.fetchall()]
    conn.close()
    return jsonify(rows)

@app.route("/api/history")
def api_history():
    conn = sqlite3.connect(DB_PATH)
    conn.row_factory = sqlite3.Row
    cur = conn.cursor()
    cur.execute("""
        SELECT mesin_id, diagnosed_at, verdict, fault_type,
               score_total, confidence
        FROM diagnoses ORDER BY diagnosed_at DESC LIMIT 20
    """)
    rows = [dict(r) for r in cur.fetchall()]
    conn.close()
    return jsonify(rows)

@app.route("/api/record_baseline", methods=["POST"])
def api_record_baseline():
    """Endpoint untuk trigger rekam baseline dari web UI."""
    data       = request.json
    mesin_id   = data.get("mesin_id", "").strip()
    nama_mesin = data.get("nama_mesin", "").strip()
    durasi     = int(data.get("durasi", 60))

    if not mesin_id or not nama_mesin:
        return jsonify({"success": False, "error": "ID dan Nama Mesin harus diisi"})

    try:
        # Import controller utama
        import importlib.util, sys
        spec = importlib.util.spec_from_file_location(
            "vibris_main",
            Path(__file__).parent / "vibris_main.py"
        )
        mod = importlib.util.load_from_spec(spec)
        spec.loader.exec_module(mod)

        ctrl = mod.VibrisController()
        baseline_id = ctrl.record_baseline(mesin_id, nama_mesin, durasi)
        return jsonify({"success": True, "baseline_id": baseline_id})
    except Exception as e:
        return jsonify({"success": False, "error": str(e)})

@app.route("/api/diagnose", methods=["POST"])
def api_diagnose():
    """Endpoint untuk trigger diagnosa dari web UI."""
    data     = request.json
    mesin_id = data.get("mesin_id", "").strip()
    durasi   = int(data.get("durasi", 120))

    try:
        import importlib.util
        spec = importlib.util.spec_from_file_location(
            "vibris_main",
            Path(__file__).parent / "vibris_main.py"
        )
        mod = importlib.util.util.load_from_spec(spec) if False else None

        # Langsung import
        sys_path = str(Path(__file__).parent)
        import sys
        if sys_path not in sys.path:
            sys.path.insert(0, sys_path)

        from vibris_main import VibrisController
        ctrl   = VibrisController()
        result = ctrl.diagnose_machine(mesin_id, durasi)

        if "error" in result:
            return jsonify({"success": False, "error": result["error"]})

        # Bersihkan numpy types untuk JSON serialization
        clean = {k: float(v) if hasattr(v, '__float__') else v
                 for k, v in result.items()
                 if k != "features"}
        return jsonify({"success": True, "result": clean})
    except Exception as e:
        return jsonify({"success": False, "error": str(e)})


